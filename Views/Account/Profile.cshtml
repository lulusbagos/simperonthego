@model SimperSecureOnlineTestSystem.ViewModels.ProfileManageViewModel
@{
    ViewData["Title"] = "My Profile";
    var avatarText = string.IsNullOrWhiteSpace(Model.FullName)
        ? "U"
        : string.Concat(Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => char.ToUpperInvariant(x[0])));
    var roleLabel = Model.Role switch
    {
        "Administrator" => "Administrator",
        "Instructor" => "Instructor",
        _ => "Company Admin"
    };
    var homeController = Model.Role == "Instructor" ? "Practical" : "Admin";
    var homeAction = Model.Role == "Instructor" ? "MyAssignments" : "Dashboard";
}

<div class="row justify-content-center">
    <div class="col-xl-10">
        @if (TempData["ProfileSuccess"] is string profileSuccess)
        {
            <div class="alert alert-success">@profileSuccess</div>
        }

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm mb-3 premium-profile-card">
                    <div class="card-body">
                        <div class="premium-profile-cover"></div>
                        <div class="premium-profile-header">
                            <div class="premium-profile-avatar-wrap">
                                <img src="~/images/profile-avatar-premium.svg" alt="Profile avatar" class="premium-profile-avatar-image" />
                                <span class="premium-profile-initials">@avatarText</span>
                            </div>
                            <div>
                                <div class="fw-semibold fs-5">@Model.FullName</div>
                                <div class="text-muted small">@Model.Username · @roleLabel</div>
                            </div>
                        </div>

                        <div class="premium-profile-meta-list">
                            <div class="premium-profile-meta">
                                <span>Workspace</span>
                                <strong>Admin Control Deck</strong>
                            </div>
                            <div class="premium-profile-meta">
                                <span>Access Role</span>
                                <strong>@roleLabel</strong>
                            </div>
                            <div class="premium-profile-meta">
                                <span>Company Scope</span>
                                <strong>@(Model.CompanyId.HasValue ? $"Company ID {Model.CompanyId}" : "Global Access")</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card border-0 shadow-sm premium-profile-form-card">
                    <div class="card-header bg-white fw-semibold">Keamanan Akun</div>
                    <div class="card-body">
                        <form asp-action="Profile" method="post">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                            <div class="premium-inline-note mb-3">
                                Foto profil saat ini menggunakan avatar premium bawaan agar tampilan admin tetap konsisten dan profesional.
                            </div>

                            <div class="mb-3">
                                <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                                <input asp-for="CurrentPassword" class="form-control premium-input" />
                            </div>

                            <div class="mb-3">
                                <label asp-for="NewPassword" class="form-label">New Password</label>
                                <input asp-for="NewPassword" class="form-control premium-input" />
                                <small class="text-muted">Minimal 6 karakter.</small>
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                <button type="submit" class="btn btn-primary">Update Password</button>
                                <a asp-controller="@homeController" asp-action="@homeAction" class="btn btn-outline-secondary">Kembali</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
