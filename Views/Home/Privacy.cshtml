@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="row justify-content-center participant-flow">
    <div class="col-lg-9 col-xl-8">
        <div class="card border-0 participant-card mt-2" data-animate="reveal">
            <div class="card-header fw-semibold">Privacy & Data Usage</div>
            <div class="card-body p-4">
                <p class="text-muted">
                    SIMPER Secure Online Test System menyimpan data peserta, hasil ujian, dan log keamanan untuk kebutuhan asesmen serta audit internal.
                </p>
                <ul class="mb-0">
                    <li>Data digunakan hanya untuk proses sertifikasi dan evaluasi kompetensi.</li>
                    <li>Akses data dibatasi berdasarkan role admin/assessor.</li>
                    <li>Aktivitas monitoring dilakukan selama sesi ujian berlangsung.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
