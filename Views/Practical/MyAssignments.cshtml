@model SimperSecureOnlineTestSystem.ViewModels.PracticalMyAssignmentsViewModel
@using SimperSecureOnlineTestSystem.Domain.Enums
@{
    ViewData["Title"] = "Penilaian Praktek";
    var pendingCount = Model.Sessions.Count(x => x.Status != PracticalAssessmentStatus.Submitted);
    var completedCount = Model.Sessions.Count(x => x.Status == PracticalAssessmentStatus.Submitted);
    var isInstructor = string.Equals(Model.UserRole, SystemUserRole.Instructor, StringComparison.OrdinalIgnoreCase);
    var pageTitle = isInstructor ? "Assignment Praktek Saya" : "Monitor Assignment Praktek";
    var subtitle = isInstructor
        ? "Halaman ini dibuat ringkas untuk instruktur: lihat assignment, buka form, isi nilai, lalu submit hasil akhir."
        : "Administrator dan company admin dapat memantau assignment praktek lintas scope, lalu langsung masuk ke template atau distribusi sesi.";
}

<div class="practical-monitor-shell">
<div class="page-head practical-monitor-head">
    <div>
        <h4 class="page-title">@pageTitle</h4>
        <p class="page-subtitle">@subtitle</p>
    </div>
    <div class="toolbar d-flex gap-2 flex-wrap">
        <span class="metric-chip">Pending: @pendingCount</span>
        <span class="metric-chip">Selesai: @completedCount</span>
        @if (!isInstructor)
        {
            <a asp-controller="Admin" asp-action="PracticalTemplates" class="btn btn-outline-primary">
                <i class="fas fa-layer-group me-1"></i>Template Praktek
            </a>
            <a asp-controller="Admin" asp-action="PracticalSessions" class="btn btn-primary">
                <i class="fas fa-calendar-check me-1"></i>Distribusi Praktek
            </a>
        }
    </div>
</div>

@if (!isInstructor)
{
    <div class="schedule-scope-banner mb-3">
        @if (string.Equals(Model.UserRole, SystemUserRole.Administrator, StringComparison.OrdinalIgnoreCase))
        {
            <span class="scope-chip admin">Mode Administrator: semua company dapat membuat template dan mengirim form praktek.</span>
        }
        else
        {
            <span class="scope-chip company">Mode Company Admin: hanya company Anda yang dapat membuat template dan mendistribusikan form.</span>
        }
        <span class="scope-chip neutral">Halaman ini menampilkan seluruh assignment sesuai scope login.</span>
    </div>
}

@if (Model.Sessions.Count == 0)
{
    <div class="practical-empty-state">
        <i class="fas fa-clipboard-check"></i>
        <div>
            <strong>@(isInstructor ? "Belum ada assignment." : "Belum ada sesi praktek terdistribusi.")</strong>
            <div class="text-muted">
                @(isInstructor
                    ? "Admin belum mengirimkan form penilaian praktek ke akun ini."
                    : "Buat template praktek terlebih dahulu, lalu kirim sesi penilaian ke instruktur dari menu Distribusi Praktek.")
            </div>
            @if (!isInstructor)
            {
                <div class="mt-3 d-flex gap-2 flex-wrap">
                    <a asp-controller="Admin" asp-action="PracticalTemplates" class="btn btn-outline-primary">
                        <i class="fas fa-layer-group me-1"></i>Buat Template
                    </a>
                    <a asp-controller="Admin" asp-action="PracticalSessions" class="btn btn-primary">
                        <i class="fas fa-paper-plane me-1"></i>Kirim Form ke Instruktur
                    </a>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="card practical-monitor-table-card">
        <div class="card-header fw-semibold d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>Daftar Assignment Praktek</span>
            <small class="text-muted">Total: @Model.Sessions.Count sesi</small>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table premium-table table-sm align-middle mb-0 practical-monitor-table">
                    <thead>
                        <tr>
                            <th>Jadwal</th>
                            <th>Perusahaan</th>
                            <th>Peserta</th>
                            <th>Unit</th>
                            <th>Template</th>
                            <th>Instruktur</th>
                            <th>Status</th>
                            <th>Hasil</th>
                            <th class="text-end">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in Model.Sessions.OrderByDescending(x => x.ScheduledAt))
                        {
                            var isSubmitted = session.Status == PracticalAssessmentStatus.Submitted;
                            var resultText = !session.PassStatus.HasValue
                                ? "-"
                                : session.PassStatus.Value
                                    ? (session.FinalNumericScore.HasValue ? $"Lulus ({session.FinalNumericScore:0.##})" : $"Lulus ({session.FinalGrade})")
                                    : (session.FinalNumericScore.HasValue ? $"Tidak Lulus ({session.FinalNumericScore:0.##})" : $"Tidak Lulus ({session.FinalGrade})");
                            <tr>
                                <td class="text-nowrap">@session.ScheduledAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                <td>@session.CompanyName</td>
                                <td>
                                    <div class="fw-semibold">@session.Nrp - @session.EmployeeName</div>
                                    <small class="text-muted">KTP: @(string.IsNullOrWhiteSpace(session.Ktp) ? "-" : session.Ktp)</small>
                                </td>
                                <td>@session.VehicleName</td>
                                <td>@session.TemplateName</td>
                                <td>@session.InstructorName</td>
                                <td>
                                    <span class="badge practical-status-badge @(isSubmitted ? "status-submitted" : "status-pending")">@session.Status</span>
                                </td>
                                <td class="text-nowrap">@resultText</td>
                                <td class="text-end">
                                    <a asp-action="Evaluate" asp-route-id="@session.Id" class="btn btn-sm btn-primary practical-action-btn">
                                        <i class="fas fa-pen-ruler me-1"></i>@(isSubmitted ? "Lihat" : "Nilai")
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
</div>
